generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  role          Role     @default(PARENT)
  phone         String?
  createdAt     DateTime @default(now())
  coachProfile  Coach?
  parentProfile Parent?
  playerProfile Player?
}

model Coach {
  id          String       @id @default(cuid())
  userId      String       @unique
  specialty   String?
  exp         Int?
  cert        String?
  salary      Float?
  groupId     String?      @unique  // Required for Prisma one-to-one relation - uniqueness enforced by DB
  perms       Json?
  attendance  Attendance[]
  group       Group?       @relation("GroupCoach", fields: [groupId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  evaluations Evaluation[]
  trainings   Training[]
}

model Parent {
  id      String   @id @default(cuid())
  userId  String   @unique
  user    User     @relation(fields: [userId], references: [id])
  players Player[]
}

model Player {
  id            String       @id @default(cuid())
  userId        String?      @unique
  name          String
  age           Int
  phone         String?
  status        String       @default("نشط")
  position      String?
  weight        Float?
  height        Float?
  joinDate      DateTime     @default(now())
  score         Int          @default(80)
  speed         Int          @default(75)
  stamina       Int          @default(75)
  technique     Int          @default(75)
  teamwork      Int          @default(75)
  goals         Int          @default(0)
  assists       Int          @default(0)
  attendancePct Int          @default(90)
  groupId       String?
  parentId      String
  evaluations   Evaluation[]
  payments      Payment[]
  group         Group?       @relation(fields: [groupId], references: [id])
  parent        Parent       @relation(fields: [parentId], references: [id])
  user          User?        @relation(fields: [userId], references: [id])
}

model Group {
  id         String       @id @default(cuid())
  name       String
  color      String       @default("#06B6D4")
  coachId    String?      @unique  // One-to-one: one coach per group, enforced at DB level
  attendance Attendance[]
  coach      Coach?       @relation("GroupCoach")
  players    Player[]
  trainings  Training[]
}

model Payment {
  id         String   @id @default(cuid())
  playerId   String
  coachId    String?
  coachName  String?
  type       String
  month      String
  amount     Float
  date       DateTime @default(now())
  note       String?
  playerName String?
  player     Player   @relation(fields: [playerId], references: [id])
}

model Attendance {
  id      String   @id @default(cuid())
  date    DateTime
  groupId String
  coachId String?
  records Json
  coach   Coach?   @relation(fields: [coachId], references: [id])
  group   Group    @relation(fields: [groupId], references: [id])
}

model Evaluation {
  id        String   @id @default(cuid())
  playerId  String
  coachId   String
  date      DateTime @default(now())
  note      String?
  speed     Int
  technique Int
  teamwork  Int
  coach     Coach    @relation(fields: [coachId], references: [id])
  player    Player   @relation(fields: [playerId], references: [id])
}

model Message {
  id       String   @id @default(cuid())
  fromName String
  toName   String
  text     String
  date     DateTime @default(now())
  read     Boolean  @default(false)
  files    Json?
  from     String
  to       String
}

model Training {
  id            String    @id @default(cuid())
  groupId       String
  coachId       String
  days          String[]
  time          String
  duration      Int
  field         String
  title         String?
  trainingFocus String?
  note          String?
  date          DateTime?
  coach         Coach     @relation(fields: [coachId], references: [id])
  group         Group     @relation(fields: [groupId], references: [id])
}

enum Role {
  ADMIN
  COACH
  PARENT
  PLAYER
}
